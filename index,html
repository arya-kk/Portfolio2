<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aryananda K | Portfolio</title>
    <style>
        /* --- General Reset & Variables --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: background-color 0.3s, color 0.3s, transform 0.3s;
        }

        html {
            scroll-behavior: smooth;
        }

        :root {
            --bg-color: #f5f5f0;
            --card-bg: #d9e2ec;
            --text-color: #1a1a1a;
            --hero-bg: #ffffff;
            --btn-color: #3ca0c4;
            --nav-bg: #222;
        }

        [data-theme="dark"] {
            --bg-color: #121212;
            --card-bg: #1e293b;
            --text-color: #f8fafc;
            --hero-bg: #1a1a1a;
            --btn-color: #38bdf8;
            --nav-bg: #000000;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
            text-align: center;
        }

        /* --- Navigation --- */
        nav {
            background-color: var(--nav-bg);
            padding: 1.5rem;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-links {
            display: flex;
            justify-content: center;
            list-style: none;
        }

        .nav-links li a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-size: 1.1rem;
            font-weight: 500;
        }

        .nav-links li a:hover {
            color: var(--btn-color);
        }

        /* --- Hero Section --- */
        .hero {
            padding: 80px 20px;
            background-color: var(--hero-bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .profile-img {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid var(--btn-color);
            margin-bottom: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .hero h1 {
            font-size: 2.8rem;
            margin-bottom: 5px;
        }

        .hero h2 {
            font-weight: 400;
            color: var(--btn-color);
            margin-bottom: 15px;
        }

        /* --- Projects Section --- */
        .projects-section {
            padding: 60px 20px;
        }

        .project-card {
            background-color: var(--card-bg);
            max-width: 600px;
            margin: 0 auto 30px;
            padding: 40px 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .project-card:hover {
            transform: translateY(-8px);
        }

        .view-btn, .resume-btn {
            background-color: var(--btn-color);
            color: white;
            padding: 10px 25px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 600;
            display: inline-block;
            margin-top: 15px;
            cursor: pointer;
            border: none;
        }

        .resume-btn {
            margin-top: 25px;
            background: transparent;
            border: 2px solid var(--btn-color);
            color: var(--btn-color);
        }

        .resume-btn:hover {
            background: var(--btn-color);
            color: white;
        }

        /* --- Skills --- */
        .skill-tag {
            display: inline-block;
            background: var(--card-bg);
            padding: 8px 18px;
            margin: 5px;
            border-radius: 20px;
            font-weight: bold;
        }

        /* --- Dark Mode Toggle --- */
        #theme-toggle {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background-color: var(--btn-color);
            color: white;
            border: none;
            cursor: pointer;
            font-size: 1.5rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            z-index: 1001;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        footer {
            padding: 50px 20px;
            border-top: 1px solid #ddd;
        }

        .contact-links {
            display: flex;
            flex-direction: column;
            gap: 12px;
            align-items: center;
        }
    </style>
</head>
<body>

    <button id="theme-toggle" title="Toggle Dark/Light Mode">🌓</button>

    <nav>
        <ul class="nav-links">
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <header id="about" class="hero">
        <img src="IMG_0953.JPG.jpeg" alt="Aryananda K" class="profile-img">
        
        <h1>Aryananda K</h1>
        <h2>Computer Science Student</h2>
        <p>A passionate developer interested in web development and problem solving.</p>
        
        <a href="resume.pdf" class="resume-btn" download>Download Resume</a>
    </header>

    <section id="projects" class="projects-section">
        <h2>Projects</h2>
        <div class="project-card">
            <h3>Book Resale Platform</h3>
            <p>Website for students to buy/sell used books.</p>
            <a href="https://student-7169e.web.app" target="_blank" class="view-btn">View Project</a>
        </div>
        <div class="project-card">
            <h3>Portfolio Website</h3>
            <p>My personal responsive portfolio.</p>
            <a href="#" class="view-btn">View Code</a>
        </div>
    </section>

    <section id="skills" style="padding-bottom: 50px;">
        <h2>Skills</h2>
        <div class="skill-tag">HTML</div>
        <div class="skill-tag">CSS</div>
        <div class="skill-tag">JavaScript</div>
        <div class="skill-tag">Python</div>
        <div class="skill-tag">C</div>
    </section>

    <footer id="contact">
        <h2>Contact</h2>
        <div class="contact-links">
            <a href="mailto:achuaryananda035@gmail.com" style="color: var(--btn-color); text-decoration: none; font-weight: bold;">achuaryananda035@gmail.com</a>
            <a href="https://www.linkedin.com/in/aryananda-k-a2471237b" target="_blank" style="color: var(--btn-color); text-decoration: none; font-weight: bold;">LinkedIn Profile</a>
        </div>
        <p style="margin-top: 20px; font-size: 0.8rem; opacity: 0.6;">&copy; 2026 Aryananda K</p>
    </footer>

    <script>
        const toggleBtn = document.getElementById('theme-toggle');
        const body = document.documentElement;

        toggleBtn.addEventListener('click', () => {
            if (body.hasAttribute('data-theme')) {
                body.removeAttribute('data-theme');
                toggleBtn.innerText = '🌓';
            } else {
                body.setAttribute('data-theme', 'dark');
                toggleBtn.innerText = '☀️';
            }
        });
    </script>
</body>
</html>
